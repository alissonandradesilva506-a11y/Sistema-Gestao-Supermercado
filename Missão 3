class Produto {
    private String nome;
    private double preco;
    private int estoque;
    
    public Produto(String n, double p, int e){
        this.nome = n;
        this.preco = p;
        this.estoque = e;  
    }

    public String getNome(){
        return nome;
    }
    public void setNome(String n){
        this.nome = n;
    }
    
    public double getPreco(){
        return preco;
    } 
    public void setPreco(double p){
        if (p<0){
            this.preco = 0;
            System.out.println("Erro: Não é permitido inserir valores negativos.");
        }else{
            this.preco = p;
        }
    }
    
    public int getEstoque(){
        return estoque;
    }
    public void setEstoque(int e){
        if (e<0){
            this.estoque = 0;
            System.out.println("Erro: Não é permitido inserir valores negativos.");
        }else{
            this.estoque = e;
        }
    }
    
    public void adicionarEstoque(int qtd){
        estoque += qtd;
    }
    
    public void vender(int qtd){
        if(estoque >= qtd) {
            estoque -= qtd;
            System.out.println("Vendido " + qtd + " unidades de " + this.nome);
        } else {
            System.out.println("Estoque insuficiente para " + this.nome);
    }
    
    class Perecivel extends Produto{
        private String dataValidade;
        
        public Perecivel(String n, double p, int e, String data) {
            this.dataValidade = data;
            super(n, p, e);
        }
        
        public String getDataValidade(){
            return dataValidade;
        }
         
        public void setDataValidade(String data){
            this.dataValidade = data;
        }
        
        @Override
        public void vender(int qtd){
            System.out.println("Verificando validade do produto: " + this.nome + "...");
        
        
            if(this.estoque < qtd){
                System.out.println("Erro: Estoque insuficiente. Perecível precisa de reposição.");
            } else {
                this.estoque -= qtd;
                System.out.println("Perecível vendido. Validade: " + this.dataValidade);
            }
        }
    }
    class ProdutoImportado extends Produto{
        private float taxaImportacao;
        
        public ProdutoImportado(String n, double p, int e, float taxa) {
            super(n, p, e);
            this.taxaImportacao = taxa;
        }
        
        @Override
        public void vender(int qtd){
            double precoTotal = getPreco()* qtd;
            double taxa = precoTotal*(this.taxaImportacao/100);
            double precoFinal = precoTotal + taxa;
            
            System.out.println("Venda de Produto Importado:");
            System.out.println("Preço base: " + precoTotal);
            System.out.println("Taxa aplicada ("+taxaImportacao+"%): " + taxa);
            System.out.println("Preço final: " + precoFinal);
            
            super.vender(qtd);
        }
    }

    class Venda {
        public void processarItem(Produto p, int quantidade){
            double valorTotal = p.getPreco()* quantidade;
            System.out.println("--- Recibo ---");
            System.out.println("Produto: " + p.getNome());
            System.out.println("Qtd: " + quantidade);
            System.out.println("Total: R$" + valorTotal);
            
            p.vender(quantidade);
            System.out.println("-------------\n");
        }
    }   
}
